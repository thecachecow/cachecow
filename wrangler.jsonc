{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cachecow",
  "main": "src/index.js",
  "compatibility_date": "2026-04-01",
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "ai": {
    "binding": "AI"
  },
  "observability": {
    "enabled": true
  }
}
